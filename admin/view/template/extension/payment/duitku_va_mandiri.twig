{{ header }}{{ column_left }}
<div id="content">
<div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-payment" class="btn btn-primary"><i class="fa fa-check-circle"></i> {{ button_save }}</button>
        <a href="{{ cancel }}" class="btn btn-default"><i class="fa fa-reply"></i> {{ button_cancel }}</a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <h4 class="alert alert-danger"><i class="fa fa-exclamation-triangle"></i>This Payment Method will be removed in future release</h4>
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-payment" class="form-horizontal">
          
		  <div class="form-group">
            <label class="col-sm-2 control-label" for="input-mode">{{ entry_status }}</label>
            <div class="col-sm-10">
			<select name="payment_duitku_va_mandiri_status" id="input-mode" class="form-control">
                {% if payment_duitku_va_mandiri_status %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                <option value="0">{{ text_disabled }}</option>
                {% else %}
                <option value="1">{{ text_enabled }}</option>
                <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>
		  
		  
		  <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-merchant-id">{{ entry_display_name }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_duitku_va_mandiri_display_name" value="{{ payment_duitku_va_mandiri_display_name }}" placeholder="{{ entry_display_name }}" id="input-merchant-id" class="form-control" />
              {% if error.display_name %}
              <div class="text-danger">{{ error.display_name }}</div>
              {% endif %}
            </div>
          </div>
		  
		  <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-merchant-endpoint">{{ entry_endpoint }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_duitku_va_mandiri_endpoint" value="{{ payment_duitku_va_mandiri_endpoint }}" placeholder="{{ entry_endpoint }}" id="input-merchant-endpoint" class="form-control" />
              {% if error.endpoint %}
              <div class="text-danger">{{ error.endpoint }}</div>
              {% endif %}
            </div>
          </div>
		  
		  <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-merchant">{{ entry_merchant }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_duitku_va_mandiri_merchant" value="{{ payment_duitku_va_mandiri_merchant }}" placeholder="{{ entry_merchant }}" id="input-merchant" class="form-control" />
              {% if error.server_key_v2 %}
              <div class="text-danger">{{ error.server_key_v2 }}</div>
              {% endif %}
            </div>
          </div>
		  
		  
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="payment_duitku_va_mandiri_api_key">{{ entry_api_key }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_duitku_va_mandiri_api_key" value="{{ payment_duitku_va_mandiri_api_key }}" placeholder="{{ entry_api_key }}" id="payment_duitku_va_mandiri_api_key" class="form-control" />
              {% if error.client_key_v2 %}
              <div class="text-danger">{{ error.client_key_v2 }}</div>
              {% endif %}
            </div>
          </div>
		  
		<div class="form-group required">
			<label class="col-sm-2 control-label" for="payment_duitku_va_mandiri_expired">{{ entry_expired_period }}</label>
			<div class="col-sm-10">
			  <input type="text" name="payment_duitku_va_mandiri_expired" value="{{ payment_duitku_va_mandiri_expired }}" placeholder="{{ entry_expired_period }}" id="payment_duitku_va_mandiri_expired" class="form-control" />
			
              {% if error.expired_period %}
				<div class="text-danger">{{ error.expired_period }}</div>
              {% endif %}
			</div>
		</div>
		  
		  
		  {% for status in statuses %}
		   <div class="form-group">
            <label class="col-sm-2 control-label" for="input-order-status">{{ attribute(_context, 'entry_' ~ status) }}</label>
            <div class="col-sm-10">
              <select name="{{ status }}" id="duitkuPaymentType" class="form-control">
                {% for order_status in order_statuses %}
                {% if order_status.order_status_id == attribute(_context, status) %}
                <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                {% else %}
                <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>
		  {% endfor %}
		  
		   <div class="form-group">
            <label class="col-sm-2 control-label" for="input-geo-zone">{{ entry_geo_zone }}</label>
            <div class="col-sm-10">
              <select name="payment_duitku_va_mandiri_geo_zone_id" id="input-geo-zone" class="form-control">
                <option value="0">{{ text_all_zones }}</option>
                {% for geo_zone in geo_zones %}
                {% if geo_zone.geo_zone_id == payment_duitku_va_mandiri_geo_zone_id %}
                <option value="{{ geo_zone.geo_zone_id }}" selected="selected">{{ geo_zone.name }}</option>
                {% else %}
                <option value="{{ geo_zone.geo_zone_id }}">{{ geo_zone.name }}</option>
                {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>
		  
		  <div class="form-group required">
            <label class="col-sm-2 control-label" for="payment_duitku_va_mandiri_sort_order">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_duitku_va_mandiri_sort_order" value="{{ payment_duitku_va_mandiri_sort_order }}" placeholder="{{ entry_sort_order }}" id="payment_duitku_va_mandiri_sort_order" class="form-control" />
            </div>
          </div>
		<div>
			<center><font size="1">version 2.3 - This payment method will be removed in future release</font></center>
		</div>
		  
        </form>
      </div>
    </div>
  </div>
</div>
{{ footer }}